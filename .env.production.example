# Production environment template for Render
# Set these in Render Dashboard → Environment (or link an Environment Group)

PRODUCTION=true
RENDER=true

# Render sets DATABASE_URL automatically when linked to PostgreSQL
# DATABASE_URL=postgresql://...

# Public HTTPS URL (Render default or custom domain)
APP_BASE_URL=https://japanese-removals-bookings.onrender.com
PRODUCTION_DOMAIN=bookings.yourdomain.com.au

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# First admin login (created once if no staff users exist)
STAFF_USERNAME=admin
STAFF_PASSWORD=
STAFF_DISPLAY_NAME=Admin

# --- Google OAuth / Calendar / Gmail ---
GOOGLE_CALENDAR_ENABLED=true
GMAIL_INBOX_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://japanese-removals-bookings.onrender.com/integrations/google/callback
# Optional: full OAuth client JSON (single line) instead of CLIENT_ID/SECRET
# GOOGLE_OAUTH_JSON=
# After Connect Google in production, paste refreshed token JSON:
# GOOGLE_TOKEN_JSON=
GOOGLE_CALENDAR_ID=primary
CALENDAR_ORGANIZER_EMAILS=sales.sugimoto@gmail.com

# --- Xero ---
XERO_ENABLED=true
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_TENANT_ID=
XERO_REDIRECT_URI=https://japanese-removals-bookings.onrender.com/integrations/xero/callback
# XERO_TOKEN_JSON=

# --- Stripe ---
STRIPE_ENABLED=true
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Twilio SMS ---
SMS_ENABLED=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+61...
# Webhooks (configure in Twilio console):
# Status:  https://japanese-removals-bookings.onrender.com/integrations/twilio/status
# Inbound: https://japanese-removals-bookings.onrender.com/integrations/twilio/inbound

# --- Email (SMTP) ---
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Japanese Removals <noreply@yourdomain.com.au>

TIMEZONE=Australia/Perth
COMPANY_NAME=Japanese Removals
