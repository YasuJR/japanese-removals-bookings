# Copy to .env and fill in values:  cp .env.example .env

SECRET_KEY=use-a-long-random-string-here
COMPANY_NAME=Japanese Removals
COMPANY_LEGAL_NAME=JR West Pty Ltd
COMPANY_PHONE=0481 089 573

# --- Google Calendar (local dev on http://127.0.0.1) ---
OAUTHLIB_INSECURE_TRANSPORT=1
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_CREDENTIALS_FILE=credentials/google_credentials.json
GOOGLE_TOKEN_FILE=credentials/google_token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5001/integrations/google/callback
# Phase 5 — Gmail inbox → auto-create Pending bookings
GMAIL_INBOX_ENABLED=true
# Never use as “Email Customer” in calendar event text (comma-separated)
CALENDAR_ORGANIZER_EMAILS=sales.sugimoto@gmail.com

# --- SMS (Twilio) ---
SMS_ENABLED=true
SMS_ON_BOOKING_CREATE=true
SMS_ON_BOOKING_UPDATE=false
# Delivery webhooks: Twilio POSTs to /integrations/twilio/status (use a public URL in production)

# --- Email (SMTP) — for review requests & other automations ---
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Japanese Removals <noreply@example.com>

# Public URL for tracked review links in SMS/email
APP_BASE_URL=http://127.0.0.1:5001

# --- Production (Render) — see .env.production.example and docs/DEPLOYMENT.md ---
# DATABASE_URL=          # Set automatically on Render PostgreSQL
# PRODUCTION=true
# PRODUCTION_DOMAIN=bookings.yourdomain.com.au
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+61...

# --- Xero (credentials can also be saved via Settings → Xero) ---
XERO_ENABLED=true
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:5001/integrations/xero/callback
XERO_TOKEN_FILE=credentials/xero_token.json
XERO_TENANT_ID=

# --- Invoice defaults (local placeholder until Xero API) ---
INVOICE_DEFAULT_HOURLY_RATE=180
INVOICE_DEFAULT_CALLOUT_FEE=90
INVOICE_GST_ENABLED_DEFAULT=true
INVOICE_DUE_DAYS=7
INVOICE_BANK_ACCOUNT_NAME=JR West Pty Ltd
INVOICE_BANK_BSB=036308
INVOICE_BANK_ACCOUNT_NUMBER=405623

# --- Job profit dashboard (internal cost estimates) ---
PROFIT_LABOUR_COST_PER_MOVER_HOUR=45
PROFIT_FUEL_COST_PER_JOB=30
PROFIT_FUEL_COST_PER_HOUR=8
PROFIT_SUPER_PCT=11.5
PROFIT_WORKERS_COMP_PCT=6
PROFIT_MERCHANT_FEE_PCT=1.5
